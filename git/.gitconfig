[user]
	name = sami
	email = your-email@example.com

[includeIf "gitdir:~/work/"]
	path = ~/.gitconfig-work

[url "git@github.com:"]
	insteadOf = https://github.com/

[core]
	editor = nvim -f

[alias]
	prune-merged = "!git fetch --prune && git branch -vv | grep \"\\[.*/.*: gone\\] \" | awk '{print $1}' | xargs -r git branch -d"

