	"agent": {
		"general": {
			"description": "Research agent for web searches and documentation lookups. Uses Exa search as primary source.",
			"mode": "subagent",
			"model": "opencode-go/deepseek-v4-flash",
			"prompt": "Research agent. Be concise and evidence-first.\n\nRules:\n- Use websearch for discovery. Use webfetch only for exact wording from a known page.\n- Prefer official docs, specs, and vendor sources.\n- Cite source URLs for factual claims.\n- If sources do not support a claim, say unknown. Do not guess.\n- Return compact findings for handoff; avoid broad background.",
			"permission": {
				"edit": "deny",
				"bash": "deny",
				"webfetch": "allow",
				"websearch": "allow"
			}
		},
		"explore": {
			"description": "Fast read-only codebase explorer for file patterns, code search, and structure.",
			"mode": "subagent",
			"model": "opencode-go/deepseek-v4-flash",
			"prompt": "Codebase research agent. Prioritize speed, precision, and low-hallucination summaries.\n\nRules:\n- Use glob for file discovery, grep for pattern search, and read only for confirmation or minimal context.\n- Ground findings in repository evidence with file paths and line numbers when available.\n- If something is not found in the repo, state not found. Do not infer missing code.\n- Use websearch only for external API or library docs, never for repo facts.\n- Return compact findings for handoff; do not edit files.",
			"permission": {
				"read": {
					"*": "allow",
					"~/.ssh/**": "deny",
					"~/.gnupg/**": "deny",
					"~/.aws/**": "deny",
					"~/.azure/**": "deny",
					"~/.kube/**": "deny",
					"~/.docker/**": "deny",
					"~/.config/gcloud/**": "deny",
					".env*": "deny",
					"**/.env*": "deny",
					"*.pem": "deny",
					"**/*.pem": "deny",
					"*.key": "deny",
					"**/*.key": "deny",
					"*.p12": "deny",
					"**/*.p12": "deny",
					"*.jks": "deny",
					"**/*.jks": "deny",
					"*credentials*": "deny",
					"**/*credentials*": "deny"
				},
				"glob": "allow",
				"grep": {
					"*": "allow",
					"~/.ssh/**": "deny",
					"~/.gnupg/**": "deny",
					"~/.aws/**": "deny",
					"~/.azure/**": "deny",
					"~/.kube/**": "deny",
					"~/.docker/**": "deny",
					"~/.config/gcloud/**": "deny",
					".env*": "deny",
					"**/.env*": "deny",
					"*.pem": "deny",
					"**/*.pem": "deny",
					"*.key": "deny",
					"**/*.key": "deny",
					"*.p12": "deny",
					"**/*.p12": "deny",
					"*.jks": "deny",
					"**/*.jks": "deny",
					"*credentials*": "deny",
					"**/*credentials*": "deny"
				},
				"edit": "deny",
				"bash": "deny",
				"websearch": "allow"
			}
		}
	},
	"plugin": [
		"@mohak34/opencode-notifier@latest"
	]
}
