			"* unlink *": "deny",
			"*/unlink *": "deny",
			"shred *": "deny",
			"* shred *": "deny",
			"*/shred *": "deny",
			"dd *": "deny",
			"* dd *": "deny",
			"*/dd *": "deny",
			"mkfs *": "deny",
			"* mkfs *": "deny",
			"*/mkfs *": "deny",
			"wipefs *": "deny",
			"* wipefs *": "deny",
			"*/wipefs *": "deny",
			"truncate *": "deny",
			"* truncate *": "deny",
			"*/truncate *": "deny",
			"mkswap *": "deny",
			"* mkswap *": "deny",
			"*/mkswap *": "deny",
