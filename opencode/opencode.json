			"*.key": "deny",
			"**/*.key": "deny",
			"*.p12": "deny",
			"**/*.p12": "deny",
			"*.jks": "deny",
			"**/*.jks": "deny",
			"*credentials*": "deny",
			"**/*credentials*": "deny"
		},
		"external_directory": {
			"~/**": "allow",
			"~/.ssh/**": "deny",
			"~/.gnupg/**": "deny",
			"~/.aws/**": "deny",
			"~/.azure/**": "deny",
			"~/.kube/**": "deny",
			"~/.docker/**": "deny",
			"~/.config/gcloud/**": "deny"
		},
