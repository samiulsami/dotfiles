			"**/*.pem": "deny",
			"*.key": "deny",
			"**/*.key": "deny",
			"*.p12": "deny",
			"**/*.p12": "deny",
			"*.jks": "deny",
			"**/*.jks": "deny",
			"*credentials*": "deny",
			"**/*credentials*": "deny"
		},
		"webfetch": "ask",
		"lsp": "allow",
		"bash": {
