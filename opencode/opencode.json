			"tldr*": "allow",
			"man*": "allow",
			"* --help": "allow",
			"help*": "allow",
			"ls*": "allow",
			"cat*": "allow",
			"head*": "allow",
			"tail*": "allow",
			"less*": "allow",
			"more*": "allow",
			"tree*": "allow",
			"find*": "allow",
			"locate*": "allow",
			"which*": "allow",
			"whereis*": "allow",
			"pwd*": "allow",
			"df*": "allow",
			"stat*": "allow",
			"ps*": "allow",
			"file*": "allow",
			"grep*": "allow",
			"pgrep*": "allow",
			"rg*": "allow",
			"sort*": "allow",
			"uniq*": "allow",
			"wc*": "allow",
			"git status*": "allow",
			"git diff*": "allow",
			"git log*": "allow",
			"git show*": "allow",
