			"kubectl config get-contexts*": "allow",
			"kubectl top*": "allow",
			"kubectl api-resources*": "allow",
			"docker ps*": "allow",
			"docker images*": "allow",
			"docker logs*": "allow",
			"docker inspect*": "allow",
			"docker version*": "allow",
			"docker info*": "allow",
			"docker history*": "allow",
			"docker stats*": "allow",
			"top*": "allow",
			"jobs*": "allow",
			"whoami*": "allow",
			"groups*": "allow",
			"uname*": "allow",
			"uptime*": "allow",
			"date*": "allow",
