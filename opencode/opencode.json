			"* shutdown *": "deny",
			"*/shutdown *": "deny",
			"reboot *": "deny",
			"* reboot *": "deny",
			"*/reboot *": "deny",
			"poweroff *": "deny",
			"* poweroff *": "deny",
			"*/poweroff *": "deny",
			"halt *": "deny",
			"* halt *": "deny",
			"*/halt *": "deny",
			"git clean *": "deny",
			"* git clean *": "deny",
			"git reset --hard*": "deny",
			"* git reset --hard*": "deny",
			"eval*": "deny",
			"*$(*": "deny",
			"*PRODUCTION*": "deny",
			"*PROD*": "deny",
			"sudo *": "deny",
			"* sudo *": "deny",
			"*/sudo *": "deny"
		}
