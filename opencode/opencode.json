			"cargo --version*": "allow",
			"go version*": "allow",
			"java -version*": "allow",
			"node --version*": "allow",
			"python --version*": "allow",
			"helm list*": "allow",
			"helm status*": "allow",
			"helm get*": "allow",
			"helm history*": "allow",
			"helm version*": "allow",
			"git branch -D*": "ask",
			"chmod -R *": "ask",
			"chmod 000 *": "ask",
			"chmod 0 *": "ask",
			"chown *": "ask",
			"killall *": "ask",
			"pkill *": "ask",
			"kill -9 *": "ask",
