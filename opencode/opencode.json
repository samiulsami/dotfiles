	"agent": {
		"general": {
			"description": "READ ONLY Research agent for web searches and codebase exploration.",
			"mode": "subagent",
			"model": "opencode-go/deepseek-v4-flash",
			"prompt": "READ ONLY Research agent. Be concise and evidence-first.\n\nRules:\n- Use websearch for discovery. Use webfetch only for exact wording from a known page.\n- Prefer official docs, specs, and vendor sources.\n- Cite source URLs for factual claims.\n- If sources do not support a claim, say unknown. Do not guess.\n- Return compact findings for handoff; avoid broad background.",
			"permission": {
				"edit": "deny",
				"bash": "deny",
				"webfetch": "allow",
				"websearch": "allow"
			}
		},
		"explore": {
			"description": "READ ONLY Research agent for web searches and codebase exploration.",
			"mode": "subagent",
			"model": "opencode-go/deepseek-v4-flash",
			"prompt": "READ ONLY Research agent. Be concise and evidence-first.\n\nRules:\n- Use websearch for discovery. Use webfetch only for exact wording from a known page.\n- Prefer official docs, specs, and vendor sources.\n- Cite source URLs for factual claims.\n- If sources do not support a claim, say unknown. Do not guess.\n- Return compact findings for handoff; avoid broad background.",
			"permission": {
				"edit": "deny",
				"bash": "deny",
				"webfetch": "allow",
				"websearch": "allow"
			}
		},
		"implementation": {
			"description": "Implementation agent. Best for doing one narrow code change well, if given enough context: clear behavior, tight scope/files, boundaries, and concrete style/prose direction.",
			"mode": "subagent",
			"model": "opencode-go/qwen3.7-plus",
			"prompt": "Implementation-only coding agent. Implement the delegated spec inside the given scope.\n\nThe delegating agent should provide:\n- Spec: the requested behavior or code change.\n- Scope: relevant files, directories, boundaries, and non-goals.\n- Direction: concrete style, prose, product, or review constraints.\n\nRules:\n- Read enough repo context before editing.\n- Make the smallest correct change inside scope.\n- Do not redesign, broaden scope, research externally, or add speculative abstractions.\n- Preserve existing style unless direction explicitly overrides it.\n- Prefer deletion, reuse, and direct code over new helpers, layers, or dependencies.\n- Run the smallest relevant verification when feasible.\n- Return a compact handoff: changed files, verification run, and anything skipped or blocked.",
			"permission": {
				"edit": "ask",
				"bash": "ask",
				"webfetch": "deny",
				"websearch": "deny"
			}
		}
	},
	"plugin": [
		"@mohak34/opencode-notifier@latest"
	]
