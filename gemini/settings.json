{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "disableYoloMode": true,
    "blockGitExtensions": true,
    "folderTrust": {
      "enabled": false
    },
    "environmentVariableRedaction": {
      "enabled": true
    },
    "experimental": {
      "enableAgents": true
    }
  },
  "general": {
    "vimMode": true,
    "enableAutoUpdate": false,
    "debugKeystrokeLogging": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    },
    "enablePromptCompletion": false
  },
  "ui": {
    "customThemes": {
      "MyCustomTheme": {
        "name": "MyCustomTheme",
        "type": "custom",
        "background": {
          "primary": "#ffffff"
        },
        "text": {
          "primary": "#f0f0f0",
          "secondary": "#ffffff"
        }
      }
    },
    "theme": "ANSI",
    "autoThemeSwitching": false,
    "useBackgroundColor": true,
    "terminalBackgroundPollingInterval": 1
  },
  "keybindings": [
    {
      "command": "terminal.openEditor",
      "key": "ctrl+x"
    }
  ],
  "tools": {
    "shell": {
      "showColor": true
    }
  },
  "model": {
    "name": "gemini-3.1-pro-preview"
  }
}

