{
    "layer": "top",
    "position": "bottom",
    "height": 24,
    // "output": ["HDMI-A-1"],
    "modules-left": ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": ["tray"],
    "modules-right": [ "custom/dunst", "cpu", "memory", "disk", "bluetooth", "network", "pulseaudio", "pulseaudio#microphone", "battery", "clock", "idle_inhibitor" ],

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate"
    },

    "hyprland/submap": {
        "format": "{}",
        "max-length": 20
    },

    "idle_inhibitor": {
            "format": "{icon}",
            "format-icons": {
                    "activated": "َ°›ٹ ",
                    "deactivated": "َ°¾« "
            },
            "tooltip-format-activated": "Idle inhibitor: ON",
            "tooltip-format-deactivated": "Idle inhibitor: OFF"
    },

    "clock": {
        "format": "ïپ³ {:%a %d/%b/%Y ï€— %H:%M}",
        "tooltip-format": "Date and Time"
    },

    "battery": {
        "interval": 10,
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°‚„ {capacity}%",
        "format-full": "َ°‚„ {capacity}%",
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "states": {
            "warning": 30,
            "critical": 15
        },
        "tooltip-format": "Battery: {capacity}%\nTime remaining: {time}"
    },

    "network": {
        "interval": 2,
        "format-wifi": "َ°–© {essid} {signalStrength}%",
        "format-ethernet": "َ°ˆ€ {ifname}",
        "format-disconnected": "َ°–ھ Disconnected",
        "tooltip-format": "ipaddr: {ipaddr}\nَ°•’ {bandwidthUpBytes} َ°‡ڑ {bandwidthDownBytes}\nUse nmcli to manage network",
        "states": {
            "good": 50,
            "fair": 25
        }
    },

    "pulseaudio": {
        "format": "ï€¨  {volume}%",
        "format-muted": "َ°–پ",
        "tooltip-format": "Volume: {volume}%\nSuper+V: -5%\nSuper+Shift+V: +5%\nSuper+M: Toggle mute",
        "on-click": "pavucontrol"
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ï„° {volume}%",
        "format-source-muted": "ï„± ",
        "tooltip-format": "Mic: {source_volume}%\nSuper+I: -5%\nSuper+Shift+I: +5%\nSuper+Shift+M: Toggle mute",
        "on-click": "pavucontrol"
    },

    "cpu": {
        "interval": 5,
        "format": "ï’¼ {usage}%",
        "tooltip-format": "CPU: Run btop for detailed process info",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "memory": {
        "interval": 5,
        "format": "î؟… {used:0.1f}GB/{total:0.1f}GB",
        "tooltip-format": "Memory: Run btop for detailed process info",
        "states": {
            "warning": 75,
            "critical": 90
        }
    },

    "disk": {
        "interval": 60,
        "format": "َ°‹ٹ {used}/{total}",
        "path": "/",
        "tooltip-format": "Disk usage",
        "states": {
            "warning": 80,
            "critical": 95
        }
    },

    "bluetooth": {
        "interval": 10,
        "format": "َ°‚¯ {status}",
        "format-connected": "َ°‚¯ {device_alias} {device_battery_percentage}%",
        "tooltip-format": "Bluetooth\nUse bluetoothctl to manage devices"
    },

    "tray": {
        "spacing": 10
    },

    "custom/dunst": {
        "exec": "${XDG_CONFIG_HOME:-$HOME/.config}/waybar/dunst.sh",
        "return-type": "json",
        "signal": 1,
        "interval": "once",
        "on-click": "dunstctl set-paused toggle && pkill -RTMIN+1 waybar",
        "tooltip-format": "Notifications\nSuper+N: History pop\nSuper+P: Close\nSuper+A: Action\nSuper+C: Close all\nSuper+Shift+S: Toggle pause"
    }
}
